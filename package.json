{
  "name": "cro",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev":"turbo run dev",
    "dev:api": "turbo run dev --filter=cro-api",
    "dev:web": "turbo run dev --filter=cro-web",
    "dev:admin": "turbo run dev --filter=cro-admin",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.0"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": [
      "eslint --config apps/api/eslint.config.mjs --fix --max-warnings=0",
      "prettier --write"
    ],
    "apps/web/src/**/*.{ts,tsx}": [
      "eslint --config apps/web/eslint.config.mjs --fix --max-warnings=0",
      "prettier --write"
    ],
    "apps/admin/src/**/*.{ts,tsx}": [
      "eslint --config apps/admin/eslint.config.mjs --fix --max-warnings=0",
      "prettier --write"
    ]
  }
}
