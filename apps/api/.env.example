# Database
DATABASE_URL="postgresql://cro:cro_dev_password@localhost:5434/cro_grammar?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-random-string-min-16-chars"
JWT_REFRESH_SECRET="change-me-to-another-random-string-min-16-chars"
JWT_ACCESS_EXPIRY_SECONDS=900       # Access token lifetime in seconds (900 = 15min)
JWT_REFRESH_EXPIRY_SECONDS=2592000  # Session lifetime in seconds (2592000 = 30d, 604800 = 7d)

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# Apple OAuth (optional for local dev)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# CORS
WEB_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"

# Stripe (optional for Phase 1)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# RevenueCat (optional for Phase 1)
REVENUECAT_WEBHOOK_SECRET=""

# App
PORT=3000
NODE_ENV="development"
